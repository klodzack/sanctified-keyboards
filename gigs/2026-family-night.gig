        </WIDGET>
      </RACKUNIT>
    </RACKVIEW>
    <PRESET name="Default" pcNumber="4194051">
      <PARAM widgetId="85" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="87" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="88" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="89" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="90" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="91" value="0.6379310488700867" onLoadValue="0.6379310488700867"/>
    </PRESET>
    <SCRIPT_CONTENT>var
  MODX : MidiInBlock
Var
  WScene1, WScene2, WScene3, WScene4 : Widget
Var
  ShakerEnable : Widget

On ControlChangeEvent(m : ControlChangeMessage) From MODX
    var value : integer = m.GetCCValue()
    var scene : integer = value / 16 + 1
    
    If m.GetCCNumber() == 92
    Then
      If scene == 1
      Then
        SetWidgetValue(WScene1, 1.0)
        SetWidgetValue(WScene1, 0.0)
      End
      If scene == 2
      Then
        SetWidgetValue(WScene2, 1.0)
        SetWidgetValue(WScene2, 0.0)
      End
      If scene == 3
      Then
        SetWidgetValue(WScene3, 1.0)
        SetWidgetValue(WScene3, 0.0)
      End
      If scene == 4
      Then
        SetWidgetValue(WScene4, 1.0)
        SetWidgetValue(WScene4, 0.0)
      End
    End
End

On WidgetValueChanged (newValue : double) From WScene1
  If newValue &gt; 0.0
  Then
    Print(&quot;Switching to Scene 1&quot;)
    EnablePlayhead(false)
  End
End

On WidgetValueChanged (newValue : double) From WScene2
  If newValue &gt; 0.0
  Then
    Print(&quot;Switching to Scene 2&quot;)
    EnablePlayhead(true)
    SetWidgetValue(ShakerEnable, 0.0)
  End
End

On WidgetValueChanged (newValue : double) From WScene3
  If newValue &gt; 0.0
  Then
    Print(&quot;Switching to Scene 3&quot;)
    EnablePlayhead(true)
    SetWidgetValue(ShakerEnable, 1.0)
  End
End

On WidgetValueChanged (newValue : double) From WScene4
  If newValue &gt; 0.0
  Then
    Print(&quot;Switching to Scene 4&quot;)
    EnablePlayhead(false)
  End
End</SCRIPT_CONTENT>
  </RACKSPACE>
  <SETLISTS activeSetlist="1">
    <SETLIST name="Family Night 2025" activeSong="-1"/>
  </SETLISTS>
</GIGRACK>
