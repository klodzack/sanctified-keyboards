    <PRESET name="Default" pcNumber="2105627">
      <PARAM widgetId="52" value="0.2283464521169662" onLoadValue="0.2283464521169662"/>
      <PARAM widgetId="69" value="1.0" onLoadValue="0.0"/>
      <PARAM widgetId="70" value="1.0" onLoadValue="0.0"/>
      <PARAM widgetId="71" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="72" value="0.0" onLoadValue="0.0"/>
    </PRESET>
    <SCRIPT_CONTENT>var
  MODX : MidiInBlock
Var
  WScene1, WScene2 : Widget
Var
  BassSynthEnable, HookSynthEnable : Widget

On ControlChangeEvent(m : ControlChangeMessage) From MODX
    var value : integer = m.GetCCValue()
    var scene : integer = value / 16 + 1
    
    If m.GetCCNumber() == 92
    Then
      If scene == 1
      Then
        SetWidgetValue(WScene1, 1.0)
        SetWidgetValue(WScene1, 0.0)
      End
      If scene == 2
      Then
        SetWidgetValue(WScene2, 1.0)
        SetWidgetValue(WScene2, 0.0)
      End
    End
End

On WidgetValueChanged (newValue : double) From WScene1
  If newValue &gt; 0.0
  Then
    Print(&quot;Switching to Scene 1&quot;)
    SetWidgetValue(BassSynthEnable, 1.0)
    SetWidgetValue(HookSynthEnable, 1.0)
  End
End

On WidgetValueChanged (newValue : double) From WScene2
  If newValue &gt; 0.0
  Then
    Print(&quot;Switching to Scene 2&quot;)
    SetWidgetValue(BassSynthEnable, 0.0)
    SetWidgetValue(HookSynthEnable, 0.0)
  End
End
</SCRIPT_CONTENT>
  </RACKSPACE>
  <RACKSPACE name="Pompeii" uid="950a0e9ac4b84891b02a33133a176987" bpm="120.0"
