    <PRESET name="Default" pcNumber="4194049">
      <PARAM widgetId="55" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="56" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="61" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="62" value="1.0" onLoadValue="1.0"/>
      <PARAM widgetId="63" value="0.7065637111663818" onLoadValue="0.7065637111663818"/>
      <PARAM widgetId="64" value="0.346997082233429" onLoadValue="0.5949951410293579"/>
      <PARAM widgetId="65" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="66" value="0.0" onLoadValue="0.0"/>
      <PARAM widgetId="67" value="0.0" onLoadValue="0.0"/>
    </PRESET>
    <SCRIPT_CONTENT>var
  MODX : MidiInBlock
Var
  WScene1, WScene2, WScene3 : Widget
Var
  VocoderEnable, CleanVocalsEnable, RadioFilterVocalsEnable, RadioFilterPianoEnable : Widget

On ControlChangeEvent(m : ControlChangeMessage) From MODX
    var value : integer = m.GetCCValue()
    var scene : integer = value / 16 + 1
    
    If m.GetCCNumber() == 92
    Then
      If scene == 1
      Then
        SetWidgetValue(WScene1, 1.0)
        SetWidgetValue(WScene1, 0.0)
      End
      If scene == 2
      Then
        SetWidgetValue(WScene2, 1.0)
        SetWidgetValue(WScene2, 0.0)
      End
      If scene == 3
      Then
        SetWidgetValue(WScene3, 1.0)
        SetWidgetValue(WScene3, 0.0)
      End
    End
End

On WidgetValueChanged (newValue : double) From WScene1
  If newValue &gt; 0.0
  Then
    Print(&quot;Switching to Scene 1&quot;)
    SetWidgetValue(VocoderEnable, 0.0)
    SetWidgetValue(CleanVocalsEnable, 1.0)
    SetWidgetValue(RadioFilterVocalsEnable, 1.0)
    SetWidgetValue(RadioFilterPianoEnable, 1.0)
  End
End

On WidgetValueChanged (newValue : double) From WScene2
  If newValue &gt; 0.0
  Then
    Print(&quot;Switching to Scene 2&quot;)
    SetWidgetValue(VocoderEnable, 0.0)
    SetWidgetValue(CleanVocalsEnable, 1.0)
    SetWidgetValue(RadioFilterVocalsEnable, 0.0)
    SetWidgetValue(RadioFilterPianoEnable, 0.0)
  End
End

On WidgetValueChanged (newValue : double) From WScene3
  If newValue &gt; 0.0
  Then
    Print(&quot;Switching to Scene 3&quot;)
    SetWidgetValue(VocoderEnable, 1.0)
    SetWidgetValue(CleanVocalsEnable, 0.0)
    SetWidgetValue(RadioFilterVocalsEnable, 0.0)
    SetWidgetValue(RadioFilterPianoEnable, 0.0)
  End
End</SCRIPT_CONTENT>
